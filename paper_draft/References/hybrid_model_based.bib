@article{Hu2021LeakReview,
  author  = {Hu, Zukang and Chen, Beiqing and Chen, Wenlong and Tan, Debao and Shen, Dingtao},
  title   = {Review of model-based and data-driven approaches for leak detection and location in water distribution systems},
  journal = {Water Supply},
  year    = {2021},
  volume  = {21},
  number  = {7},
  pages   = {3282--3306},
  month   = apr,
  issn    = {1606-9749},
  doi     = {10.2166/ws.2021.101},
  url     = {https://doi.org/10.2166/ws.2021.101},
  abstract = {Leak detection and location in water distribution systems (WDSs) is of utmost importance for reducing water loss, which is, however, a major challenge for water utility companies. Researchers have proposed a multitude of methods to detect leaks in WDSs. Model-based and data-driven approaches are reviewed and classified according to detection methods. Model-based approaches require highly calibrated hydraulic models and are sensitive to uncertainties, while data-driven approaches do not require in-depth system knowledge but may suffer from high false positive rates. Neither approach effectively handles anomalous variations caused by unexpected water demands.}
}