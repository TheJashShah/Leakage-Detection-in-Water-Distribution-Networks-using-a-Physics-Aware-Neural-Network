
@article{mu_st-gpinn_2025,
	title = {{ST}-{GPINN}: a spatio-temporal graph physics-informed neural network for enhanced water quality prediction in water distribution systems},
	volume = {8},
	issn = {2059-7037},
	url = {https://doi.org/10.1038/s41545-025-00499-7},
	doi = {10.1038/s41545-025-00499-7},
	abstract = {Data-driven models often neglect the underlying physical principles, limiting generalization capabilities in water distribution systems (WDSs). This study presents a novel spatio-temporal graph physics-informed neural network (ST-GPINN) for water quality prediction in WDSs, integrating hydraulic simulations, physics-informed neural networks (PINNs), and graph neural networks (GNNs) to capture dynamics and graph-based network connectivity while approximating partial differential equations (PDEs). ST-GPINN discretizes WDSs using virtual nodes to enhance spatial granularity, employs an Encoder-Processor-Decoder architecture for predictions. Validated on Network A (a small-scale network with 9 junctions and 11 pipes) and Network B (a real large-scale WDS with 920 junctions and 1032 pipes), ST-GPINN outperforms others, achieving a MAE of 0.0073 mg/L, RMSE of 0.0121 mg/L, and R2 of 88.91\% in Network A, and a MAE of 0.008 mg/L, RMSE of 0.0098 mg/L, and R² of 98.91\% in Network B. Its scalability and accuracy highlight ST-GPINN’s potential for water quality predictions.},
	number = {1},
	journal = {npj Clean Water},
	author = {Mu, Tianwei and Duan, Feiyu and Ning, Baokuan and Zhou, Bo and Liu, Junyu and Huang, Manhong},
	month = aug,
	year = {2025},
	pages = {74},
}
