   "source": [
    "import random\n",
    "\n",
    "seen = set()\n",
    "SCENARIO_IDS = []\n",
    "\n",
    "all = list(range(1, 1000))\n",
    "\n",
    "for i in range(100):\n",
    "    \n",
    "    random_id = random.choice(all)\n",
    "    \n",
    "    if random_id not in seen:\n",
    "        SCENARIO_IDS.append(random_id)\n",
    "        seen.add(random_id)"
   ]
